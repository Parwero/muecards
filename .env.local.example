# =====================================================
# Muecards — Environment Variables
# Copy this file to .env.local and fill the values.
# Never commit .env.local to git.
# =====================================================

# --- Supabase ---------------------------------------------------------------
# Project URL — Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# anon public key — Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# service_role key — Settings → API → Project API keys → service_role
# ⚠️  SERVER-ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# --- Instagram Graph API ----------------------------------------------------
# Long-lived Page Access Token with the following scopes:
#   instagram_basic, instagram_content_publish, pages_show_list,
#   pages_read_engagement, business_management
# Generate from a Meta App that has Instagram Graph API enabled and
# exchange the short-lived token for a 60-day long-lived one.
IG_ACCESS_TOKEN="EAAG..."

# Instagram Business / Creator account ID (numeric, NOT the @username)
# Find it via:  GET /{page-id}?fields=instagram_business_account
IG_USER_ID="17841400000000000"

# Graph API version pin — bump when you test against a newer version
IG_GRAPH_VERSION="v21.0"

# --- Local folder watcher ---------------------------------------------------
# URL of your deployed app (used by scripts/watch-uploader.mjs)
MUECARDS_URL="https://muecards2.vercel.app"

# Local folder to watch for new card images (optional, these are the defaults)
# WATCH_FOLDER="G:\Mi unidad\Poke\Por Subir"
# DONE_FOLDER="G:\Mi unidad\Poke\Subidas"

# --- Vercel Cron ------------------------------------------------------------
# Random secret used to authorize cron requests. Vercel automatically sends
# this as the `Authorization: Bearer <CRON_SECRET>` header on scheduled jobs.
# Generate with:  openssl rand -hex 32
CRON_SECRET="replace-with-a-long-random-string"
